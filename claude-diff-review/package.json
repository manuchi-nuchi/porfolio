{
  "name": "claude-diff-review",
  "displayName": "Claude Diff Review",
  "description": "Inline review of Claude's changes with per-block Keep/Revert buttons",
  "version": "0.0.3",
  "publisher": "local",
  "engines": {
    "vscode": "^1.74.0"
  },
  "activationEvents": [
    "*"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "claude-diff-review.keep",      "title": "Keep This Change" },
      { "command": "claude-diff-review.revert",    "title": "Revert This Change" },
      { "command": "claude-diff-review.keepAll",   "title": "Keep All Changes in File" },
      { "command": "claude-diff-review.revertAll", "title": "Revert All Changes in File" }
    ]
  }
}
